rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }
    
    // --- Validation Blueprints ---
    
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'role', 'createdAt']) &&
             data.keys().size() <= 10 &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.role in ['farmer', 'trader'] &&
             (!data.keys().contains('displayName') || (data.displayName is string && data.displayName.size() <= 100)) &&
             (!data.keys().contains('district') || (data.district is string && data.district.size() <= 100)) &&
             (!data.keys().contains('preferredLanguage') || (data.preferredLanguage in ['en', 'te']));
    }

    function isValidPoint(p) {
      return p.keys().hasAll(['x', 'y']) && p.keys().size() == 2 &&
             p.x is number && p.x >= 0 && p.x <= 100 &&
             p.y is number && p.y >= 0 && p.y <= 100;
    }

    function isValidAsset(a) {
      return a.keys().hasAll(['id', 'type', 'points', 'label', 'createdAt']) &&
             a.keys().size() == 5 &&
             a.id is string && a.id.size() <= 64 &&
             a.type in ['polygon', 'line', 'point'] &&
             a.points is list && a.points.size() >= 1 && a.points.size() <= 50 &&
             isValidPoint(a.points[0]) &&
             a.label is string && a.label.size() <= 100 &&
             a.createdAt is string;
    }

    function isValidFarm(data) {
      return data.keys().hasAll(['ownerId', 'name', 'cropType']) &&
             data.keys().size() <= 20 &&
             data.ownerId == request.auth.uid &&
             data.name is string && data.name.size() <= 100 &&
             data.cropType is string && data.cropType.size() <= 50 &&
             (!data.keys().contains('area') || (data.area is number && data.area >= 0)) &&
             (!data.keys().contains('soilType') || (data.soilType is string && data.soilType.size() <= 50)) &&
             (!data.keys().contains('lat') || (data.lat is number)) &&
             (!data.keys().contains('lng') || (data.lng is number)) &&
             (!data.keys().contains('ndviScore') || (data.ndviScore is number && data.ndviScore >= 0 && data.ndviScore <= 1)) &&
             (!data.keys().contains('boundary') || (data.boundary is list && data.boundary.size() <= 50 && (data.boundary.size() == 0 || isValidPoint(data.boundary[0])))) &&
             (!data.keys().contains('assets') || (data.assets is list && data.assets.size() <= 50 && (data.assets.size() == 0 || isValidAsset(data.assets[0]))));
    }

    // --- Matches ---

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isVerified() && isOwner(userId) && isValidUser(incoming()) && incoming().createdAt == request.time;
      allow update: if isVerified() && isOwner(userId) && isValidUser(incoming()) && 
                    incoming().uid == existing().uid &&
                    incoming().createdAt == existing().createdAt &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'district', 'preferredLanguage', 'updatedAt']) &&
                    (!incoming().keys().contains('updatedAt') || incoming().updatedAt == request.time);
    }

    match /farms/{farmId} {
      allow list: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.ownerId == request.auth.uid;
      allow create: if isVerified() && isValidId(farmId) && isValidFarm(incoming()) && 
                    (!incoming().keys().contains('updatedAt') || incoming().updatedAt == request.time);
      allow update: if isVerified() && isOwner(existing().ownerId) && isValidFarm(incoming()) &&
                    incoming().ownerId == existing().ownerId &&
                    (
                      // Action: Edit Meta
                      incoming().diff(existing()).affectedKeys().hasOnly(['name', 'area', 'cropType', 'soilType', 'lat', 'lng', 'updatedAt']) ||
                      // Action: Update Boundary
                      incoming().diff(existing()).affectedKeys().hasOnly(['boundary', 'boundaryUpdatedAt', 'updatedAt']) ||
                      // Action: Manage Assets
                      incoming().diff(existing()).affectedKeys().hasOnly(['assets', 'updatedAt']) ||
                      // Action: Sensor Sync
                      incoming().diff(existing()).affectedKeys().hasOnly(['ndviScore', 'updatedAt'])
                    ) &&
                    (!incoming().keys().contains('updatedAt') || incoming().updatedAt == request.time);
      allow delete: if isVerified() && isOwner(existing().ownerId);
    }

    match /alerts/{alertId} {
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow get: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update: if isVerified() && isOwner(existing().userId) && 
                    incoming().diff(existing()).affectedKeys().hasOnly(['read']);
    }
  }
}
